REKEYED_MNEMONIC=
ALGOD_ADDRESS=http://algod:8080
ALGOD_TOKEN=
ALGO_INDEXER_ADDRESS=https://mainnet-idx.algonode.cloud

# API authentication
API_PASSWORD=

# MongoDB
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USERNAME=
MONGODB_PASSWORD=
NEW_DB_NAME=cometa-updated

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Notifications
TELEGRAM_BOT_API_TOKEN=
TELEGRAM_CHANNEL_ID=0
DISCORD_NOTIFY_WEBHOOK_URL=

# Contract creation
FARM_CREATION_FEE=0
FARM_FLAT_ALGO_CREATION_FEE=0

# Optional private npm packages used by js/
NODE_AUTH_TOKEN=

# Optional Reach devnet override used only with a local node
REACH_DEVNET_ALGOD_TOKEN=
